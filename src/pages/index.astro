---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-4xl">
        Hi, I'm Nature 👋
      </h1>

      <p class="text-xl font-medium text-accent italic">
        A developer, systems thinker, and lifelong learner.
      </p>

      <p class="mt-6 text-lg font-medium">
        I'm a Computer Science graduate from NUS, currently working in the tech industry 
        with experience across <span class="underline decoration-dashed underline-offset-4">cloud infrastructure</span>, 
        <span class="underline decoration-dashed underline-offset-4">DevOps</span>, and 
        <span class="underline decoration-dashed underline-offset-4">backend development</span>.
      </p>

      <div class="mt-6">
        <p class="mt-4">
          Here, I share:
        </p>
        <ul class="mt-2 space-y-1">
          <li>✍️ Thoughts on life, work, and learning</li>
          <li>🧠 Notes on system design, infrastructure, and technical ideas</li>
          <li>🌱 Reflections on growth, career shifts, and the occasional epiphany</li>
        </ul>
      </div>

      <div class="mt-8">
        <p class="mt-4">
          I believe in learning in public — writing helps me clarify ideas, capture half-formed thoughts, and grow them over time.
        </p>

        <p class="mt-4">
          Happy exploring!
        </p>
      </div>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-6 flex flex-col sm:flex-row sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Connect with me:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
